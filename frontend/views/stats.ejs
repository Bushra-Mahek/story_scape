<%- include('partials/header.ejs') %>

<div class="stats-container">

  <h1 class="stats-title">Analytics Dashboard</h1>

  <!-- CARDS -->
  <div class="stats-cards-section">

    <div class="stats-card">
      <h3>Total Users</h3>
      <p><%= summary.totalUsers %></p>
    </div>

    <div class="stats-card">
      <h3>Total Posts</h3>
      <p><%= summary.totalPosts %></p>
    </div>

    <div class="stats-card">
      <h3>Most Active User</h3>
      <p>
        <%= summary.mostActive?.username || "N/A" %>
        (<%= summary.mostActive?.post_count || 0 %> posts)
      </p>
    </div>

  </div>


  <!-- BARS -->
  <div class="stats-bars-section">
    <h2>Posts Per User</h2>

    <%
      const maxPosts = users.length
        ? Math.max(...users.map(u => Number(u.post_count)))
        : 0;
    %>

    <% users.forEach(user => {
         const count = Number(user.post_count);
         const percent = maxPosts === 0 ? 0 : (count / maxPosts) * 100;
    %>

      <div class="bar-row">
        <div class="bar-label"><%= user.username %></div>
        <div class="bar" style="width:<%= percent %>%">
          <%= count %>
        </div>
      </div>

    <% }) %>
  </div>


  <!-- CHART -->
  <div class="stats-chart-section">
    <h2>Monthly Post Growth</h2>
    <canvas id="monthlyChart"></canvas>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const monthlyData = <%- JSON.stringify(monthly) %>;

  const ctx = document.getElementById("monthlyChart");

  new Chart(ctx, {
    type: "line",
    data: {
      labels: monthlyData.map(m => m.month),
      datasets: [{
        label: "Posts per Month",
        data: monthlyData.map(m => Number(m.post_count)),
        borderColor: "#3F3244",
        backgroundColor: "rgba(63,50,68,0.2)",
        tension: 0.3,
        fill: true
      }]
    }
  });
</script>

<%- include('partials/footer.ejs') %>