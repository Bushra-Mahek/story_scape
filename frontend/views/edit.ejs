<%- include('partials/header.ejs') %>
<main class="edit-container">
  <div class="edit-card">
    <h1 class="edit-title">Edit Post</h1>
  <form action="/posts/<%= post.id%>/edit" method="post" enctype="multipart/form-data" class="edit-form" ...>
  <div class="left-col">
    <!-- Title, Author, Change Image, Content -->
    <label for="title">Title</label>
    <input type="text" id="title" name = "title" value="<%= post.title %>" placeholder="rename title">

    <label for="author">Author</label>
    <input type="text" id="author" name="author" value="<%= post.author %>" placeholder="author" readonly>

    <label for="image">Change Image (optional)</label>
    <div class="file-row">
      <input type="file" id="image" name="image">
    </div>

    <label for="content">Content</label>
    <textarea id="content" name="content"><%= post.content %></textarea>
  </div>

  <div class="right">
    <!-- Current image preview -->
    <% if (post.image) { %>
      <label class="sr-only">Current image</label>
      <img src="<%= post.image %>" alt="Preview for <%= post.title %>" class="edit-preview" />
      <div class="preview-caption">This is the current image that will be used if you don't upload a new one.</div>
    <% } %>
  </div>
  <button type="submit" class="edit-btn">Edit Post</button>
</form>
</div>
</main>
<%- include('partials/footer.ejs') %>